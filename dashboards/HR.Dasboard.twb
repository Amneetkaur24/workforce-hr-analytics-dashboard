      <column caption=' Rank Top 1' datatype='boolean' name='[ Rank Top 2 (copy)_1729028714557449]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK([Calculation_0763107462184960]) &lt;=1'>
