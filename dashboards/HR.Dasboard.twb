          <zone fixed-size='185' forceUpdate='true' h='23125' hidden-by-user='true' id='97' is-fixed='true' type-v2='text' w='94071' x='6500' y='36375'>
            <formatted-text>
              <run bold='true' fontalignment='1' fontcolor='#03c4a1'>Welcome</run>
              <run fontalignment='1' fontcolor='#ffffff'> &lt;Full Name&gt;</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#03c4a1'>====================================================================================</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#03c4a1'>Hover</run>
              <run fontalignment='1' fontcolor='#ffffff'> over the chart to see more details.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff'>Click on the chart to</run>
              <run fontalignment='1' fontcolor='#03c4a1'> filter</run>
              <run fontalignment='1' fontcolor='#ffffff'> the entire dashboard.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff'>Click the switch icon on the top right corner to open the </run>
              <run fontalignment='1' fontcolor='#03c4a1'>filter menu</run>
              <run fontalignment='1' fontcolor='#ffffff'>.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#03c4a1'>====================================================================================</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#ffffff'>This HR Dashboard uses a dataset generated using </run>
              <run fontalignment='1' fontcolor='#03c4a1'>ChatGPT &amp;  Faker Library</run>
              <run fontalignment='1' fontcolor='#ffffff'>.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#03c4a1'>====================================================================================</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run bold='true' fontalignment='1' fontcolor='#03c4a1'>Author</run>
              <run fontalignment='1' fontcolor='#ffffff'>: Amneet Kaur</run>
              <run fontalignment='1'>Æ&#10;</run>
