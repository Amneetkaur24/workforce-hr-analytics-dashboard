          <datasource-dependencies datasource='federated.1owx76r1dt568019uj0ch0et8aft'>
            <column datatype='date' name='[Birthdate]' role='dimension' type='ordinal' />
            <column caption='Location' datatype='string' name='[Calculation_0763107470946309]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &apos;New York&apos; THEN &apos;HQ&apos;&#13;&#10;    ELSE &apos;Branch&apos;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='integer' name='[Calculation_0763107483496458]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[Birthdate], TODAY())' />
            </column>
            <column caption='Age Groups' datatype='string' name='[Calculation_0763107484495883]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0763107483496458]&lt;25 THEN &apos;&lt;25&apos;&#13;&#10;ELSEIF [Calculation_0763107483496458] &gt;=25 AND [Calculation_0763107483496458]&lt;35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_0763107483496458]&gt;=35 AND [Calculation_0763107483496458]&lt;45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_0763107483496458]&gt;=45 AND [Calculation_0763107483496458]&lt;55 THEN &apos;45-54&apos;&#13;&#10;ELSEIF [Calculation_0763107483496458]&gt;=55 THEN &apos;+55&apos;&#13;&#10;END' />
            </column>
            <column caption='Status' datatype='string' name='[Calculation_1729028687364096]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Termdate]) THEN &apos;Hired&apos;&#13;&#10;ELSE &apos;Terminated&apos;&#13;&#10;END' />
            </column>
            <column caption='avg(-1.0)' datatype='real' name='[Calculation_1729028827185163]' role='measure' type='quantitative' user:unnamed='Detailed'>
              <calculation class='tableau' formula='avg(-1.0)' />
            </column>
            <column caption='Full Name' datatype='string' name='[Calculation_1729028827541516]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[First Name]+ &apos; &apos; +[Last Name]' />
            </column>
            <column caption='Length of Hire' datatype='integer' name='[Calculation_1729028830769165]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([Termdate])&#13;&#10;Then DATEDIFF(&apos;year&apos;, [Hiredate], TODAY())&#13;&#10;ELSE DATEDIFF(&apos;year&apos;, [Hiredate], [Termdate])&#13;&#10;END' />
            </column>
